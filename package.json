{
  "name": "@spfr/figma-design-pipeline",
  "version": "0.5.0",
  "description": "Two-way Figma automation via MCP — inspect, plan, mutate, and generate code from Figma designs",
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "claude",
    "codex",
    "gemini",
    "plugin"
  ],
  "homepage": "https://github.com/spfr/figma-design-pipeline",
  "bugs": {
    "url": "https://github.com/spfr/figma-design-pipeline/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spfr/figma-design-pipeline.git"
  },
  "author": "SPFR",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "spfr-figma-design-pipeline": "./dist/index.js",
    "spfr-figma-design-pipeline-install": "./scripts/install.mjs"
  },
  "files": [
    "dist/index.js",
    "dist/plugin",
    "dist/figma-design-pipeline.mcpb",
    "scripts/install.mjs",
    "scripts/package-desktop-extension.mjs",
    "skill",
    "PUBLISHING.md",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm run build:server && npm run build:plugin",
    "build:server": "node scripts/build-server.mjs",
    "build:plugin": "node scripts/build-plugin.mjs",
    "build:desktop": "node scripts/package-desktop-extension.mjs",
    "build:figma-community": "node scripts/package-figma-community.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "install:clients": "node scripts/install.mjs",
    "prepack": "npm run build && npm run build:desktop && npm run build:figma-community",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ws": "^8.18.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.103.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.0"
  }
}
