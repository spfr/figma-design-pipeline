{
  "name": "@spicefactory/figma-design-pipeline",
  "version": "0.5.1",
  "description": "Open-source MCP pipeline for Figma: inspect designs, apply safe mutations, sync tokens, and generate code from Claude, Codex, Gemini, and Figma desktop",
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "design-to-code",
    "design-system",
    "token-sync",
    "claude",
    "codex",
    "gemini",
    "plugin",
    "claude-desktop"
  ],
  "homepage": "https://spfr.github.io/figma-design-pipeline/",
  "bugs": {
    "url": "https://github.com/spfr/figma-design-pipeline/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spfr/figma-design-pipeline.git"
  },
  "author": "SPFR",
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "@hono/node-server": "^1.19.10",
    "hono": "^4.12.7",
    "express-rate-limit": "^8.2.2",
    "ajv": "^8.18.0",
    "qs": "^6.15.0",
    "path-to-regexp": "^8.4.0"
  },
  "type": "module",
  "directories": {
    "bin": "bin"
  },
  "files": [
    "bin",
    "dist/index.js",
    "dist/plugin",
    "dist/figma-design-pipeline.mcpb",
    "scripts/install.mjs",
    "scripts/package-desktop-extension.mjs",
    "skill",
    "PUBLISHING.md",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm run build:server && npm run build:plugin",
    "build:server": "node scripts/build-server.mjs",
    "build:plugin": "node scripts/build-plugin.mjs",
    "build:desktop": "node scripts/package-desktop-extension.mjs",
    "build:figma-community": "node scripts/package-figma-community.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "install:clients": "node scripts/install.mjs",
    "prepack": "npm run build && npm run build:desktop && npm run build:figma-community",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ws": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.124.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
}
